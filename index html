<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Shaghig Avakian Makeup</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; font-size: 16px; }
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #FAF6F1;
            color: #2E1B0F;
            overflow-x: hidden;
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }
        :root {
            --beige-light: #FAF6F1;
            --beige: #F0E5D5;
            --beige-dark: #DFD3C3;
            --milk-choc: #9E7E5A;
            --milk-choc-light: #B8A082;
            --dark-choc: #3E2517;
            --dark-choc-mid: #543A2A;
            --text-muted: #7A6B5A;
            --nav-height: 70px;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--beige); }
        ::-webkit-scrollbar-thumb { background: var(--milk-choc); border-radius: 4px; }

        .loader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--dark-choc);
            display: flex; align-items: center; justify-content: center; z-index: 10000;
            transition: opacity 0.8s ease, visibility 0.8s ease;
        }
        .loader.hidden { opacity: 0; visibility: hidden; }
        .loader-text {
            font-family: 'Playfair Display', serif; font-size: 1.8rem;
            color: var(--beige); letter-spacing: 6px;
            animation: pulse 1.5s ease-in-out infinite;
        }
        @keyframes pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

        .nav {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
            padding: 20px 40px; display: flex; align-items: center; justify-content: space-between;
            transition: all 0.4s ease; background: transparent; height: var(--nav-height);
        }
        .nav.scrolled { background: rgba(46, 27, 15, 0.95); padding: 14px 40px; backdrop-filter: blur(12px); }
        .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--beige); letter-spacing: 4px; text-decoration: none; font-weight: 400; }
        .nav-links { display: flex; align-items: center; gap: 30px; list-style: none; }
        .nav-links a { color: var(--beige); text-decoration: none; font-size: 0.72rem; letter-spacing: 2.5px; text-transform: uppercase; font-weight: 400; transition: color 0.3s ease; position: relative; white-space: nowrap; }
        .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: var(--milk-choc); transition: width 0.3s ease; }
        .nav-links a:hover { color: var(--milk-choc-light); }
        .nav-links a:hover::after { width: 100%; }
        .lang-toggle { display: flex; align-items: center; gap: 6px; cursor: pointer; border: 1px solid var(--milk-choc); padding: 5px 12px; border-radius: 20px; transition: all 0.3s ease; flex-shrink: 0; }
        .lang-toggle:hover { background: var(--milk-choc); }
        .lang-toggle span { color: var(--milk-choc); font-size: 0.68rem; letter-spacing: 1.5px; text-transform: uppercase; transition: color 0.3s ease; }
        .lang-toggle:hover span { color: var(--dark-choc); }
        .menu-toggle { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1001; padding: 5px; }
        .menu-toggle span { width: 24px; height: 1.5px; background: var(--beige); transition: all 0.3s ease; display: block; }
        .menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 4px); }
        .menu-toggle.active span:nth-child(2) { opacity: 0; }
        .menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -4px); }

        .mobile-menu {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--dark-choc); z-index: 999; flex-direction: column; align-items: center; justify-content: center; gap: 28px;
            opacity: 0; visibility: hidden; transition: all 0.4s ease;
        }
        .mobile-menu.active { opacity: 1; visibility: visible; }
        .mobile-menu a { color: var(--beige); text-decoration: none; font-family: 'Playfair Display', serif; font-size: 1.5rem; letter-spacing: 3px; transition: color 0.3s ease; }
        .mobile-menu a:hover { color: var(--milk-choc-light); }

        .hero {
            height: 100vh; min-height: 600px; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden;
            background: linear-gradient(160deg, #4A3324 0%, #2E1B0F 100%);
        }
        .hero-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 50% 30%, rgba(158, 126, 90, 0.2) 0%, transparent 60%);
        }
        .deco-pattern {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.06;
            background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 5 Q20 20 10 40 Q20 60 40 75 Q60 60 70 40 Q60 20 40 5Z' fill='none' stroke='%23DFD3C3' stroke-width='0.5'/%3E%3Ccircle cx='40' cy='40' r='2' fill='%23DFD3C3'/%3E%3C/svg%3E");
            background-size: 100px 100px;
        }
        .hero-content { position: relative; z-index: 2; text-align: center; padding: 0 20px; max-width: 900px; }
        .hero-sub { font-size: 0.7rem; letter-spacing: 5px; text-transform: uppercase; color: var(--milk-choc); margin-bottom: 25px; opacity: 0; transform: translateY(20px); animation: fadeUp 1s ease 0.5s forwards; }
        .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 6vw, 5rem); color: var(--beige); font-weight: 400; line-height: 1.1; margin-bottom: 15px; opacity: 0; transform: translateY(30px); animation: fadeUp 1s ease 0.7s forwards; }
        .hero-title span { color: var(--milk-choc-light); font-style: italic; }
        .hero-tag { font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 2vw, 1.3rem); color: var(--beige-dark); font-weight: 300; font-style: italic; margin-bottom: 40px; opacity: 0; transform: translateY(20px); animation: fadeUp 1s ease 0.9s forwards; }
        .hero-btn {
            display: inline-block; padding: 16px 50px; border: 1px solid var(--milk-choc); color: var(--milk-choc);
            text-decoration: none; font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; transition: all 0.4s ease;
            opacity: 0; transform: translateY(20px); animation: fadeUp 1s ease 1.1s forwards; position: relative; overflow: hidden;
        }
        .hero-btn::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--milk-choc); transition: left 0.4s ease; z-index: -1; }
        .hero-btn:hover::before { left: 0; }
        .hero-btn:hover { color: var(--dark-choc); }
        .scroll-ind { position: absolute; bottom: 35px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 2; }
        .scroll-ind span { font-size: 0.6rem; letter-spacing: 3px; text-transform: uppercase; color: var(--beige-dark); }
        .scroll-line { width: 1px; height: 35px; background: linear-gradient(to bottom, var(--milk-choc), transparent); animation: scrollAnim 2s ease-in-out infinite; }
        @keyframes scrollAnim { 0%, 100% { opacity: 0; transform: scaleY(0); transform-origin: top; } 50% { opacity: 1; transform: scaleY(1); } }
        @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

        .section { padding: 100px 40px; }
        .section-header { text-align: center; margin-bottom: 70px; }
        .section-label { font-size: 0.7rem; letter-spacing: 5px; text-transform: uppercase; color: var(--milk-choc); margin-bottom: 15px; }
        .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3.5vw, 3rem); color: var(--dark-choc); font-weight: 400; margin-bottom: 15px; }
        .section-title span { color: var(--milk-choc); font-style: italic; }
        .section-line { width: 50px; height: 1px; background: var(--milk-choc); margin: 0 auto; }

        .about { background: var(--beige-light); }
        .about-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; max-width: 1100px; margin: 0 auto; align-items: center; }
        .about-img { position: relative; aspect-ratio: 4/5; overflow: hidden; border-radius: 4px 24px 4px 24px; }
        .about-img-inner { width: 100%; height: 100%; background: linear-gradient(135deg, #E8DDD0 0%, #D4C9BA 100%); display: flex; align-items: center; justify-content: center; }
        .about-img-inner svg { width: 45%; height: auto; opacity: 0.5; }
        .about-img::after { content: ''; position: absolute; top: -10px; right: -10px; width: 100%; height: 100%; border: 1px solid var(--milk-choc); z-index: -1; border-radius: 4px 24px 4px 24px; }
        .about-text h3 { font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 2.5vw, 1.8rem); font-weight: 400; margin-bottom: 20px; color: var(--dark-choc); line-height: 1.3; }
        .about-text h3 span { color: var(--milk-choc); font-style: italic; }
        .about-text p { color: var(--text-muted); font-size: 0.95rem; line-height: 1.8; margin-bottom: 15px; font-weight: 300; }
        .about-sig { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--milk-choc); font-style: italic; margin-top: 30px; }

        .services { background: var(--beige); }
        .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 35px; max-width: 1100px; margin: 0 auto; }
        .service-card {
            background: var(--beige-light); padding: 45px 30px; text-align: center; position: relative;
            transition: all 0.5s ease; border-radius: 4px 16px 4px 16px; box-shadow: 0 4px 20px rgba(46, 27, 15, 0.05);
        }
        .service-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: var(--milk-choc); transform: scaleX(0); transition: transform 0.5s ease; border-radius: 4px 16px 0 0; }
        .service-card:hover { transform: translateY(-8px); box-shadow: 0 15px 40px rgba(46, 27, 15, 0.12); }
        .service-card:hover::before { transform: scaleX(1); }
        .service-badge { font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; color: var(--milk-choc); margin-bottom: 15px; }
        .service-name { font-family: 'Playfair Display', serif; font-size: clamp(1.2rem, 1.5vw, 1.4rem); font-weight: 500; margin-bottom: 12px; color: var(--dark-choc); }
        .service-desc { color: var(--text-muted); font-size: 0.88rem; line-height: 1.7; margin-bottom: 20px; font-weight: 300; min-height: 80px; }
        .service-price { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--milk-choc); margin-bottom: 4px; }
        .service-currency { font-size: 0.75rem; color: var(--text-muted); letter-spacing: 2px; margin-bottom: 25px; }
        .service-book {
            display: inline-block; padding: 12px 35px; border: 1px solid var(--milk-choc); color: var(--milk-choc);
            text-decoration: none; font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; transition: all 0.3s ease;
            cursor: pointer; background: none; font-family: 'Montserrat', sans-serif; border-radius: 2px;
        }
        .service-book:hover { background: var(--milk-choc); color: var(--beige-light); }

        .eye-services { background: var(--beige-light); }
        .eye-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1100px; margin: 0 auto; }
        .eye-card {
            background: var(--beige); padding: 40px 25px; text-align: center; position: relative;
            transition: all 0.5s ease; border-radius: 4px 16px 4px 16px; border: 1px solid transparent;
        }
        .eye-card:hover { border-color: var(--milk-choc); transform: translateY(-6px); box-shadow: 0 12px 35px rgba(46, 27, 15, 0.08); }
        .eye-icon { margin: 0 auto 20px; width: 50px; height: 50px; opacity: 0.6; }
        .eye-name { font-family: 'Playfair Display', serif; font-size: 1.15rem; font-weight: 500; margin-bottom: 10px; color: var(--dark-choc); }
        .eye-desc { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 18px; font-weight: 300; }
        .eye-price { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--milk-choc); margin-bottom: 3px; }
        .eye-currency { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 2px; margin-bottom: 20px; }
        .eye-book {
            display: inline-block; padding: 11px 30px; border: 1px solid var(--milk-choc); color: var(--milk-choc);
            font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase; transition: all 0.3s ease;
            cursor: pointer; background: none; font-family: 'Montserrat', sans-serif; border-radius: 2px; text-decoration: none;
        }
        .eye-book:hover { background: var(--milk-choc); color: var(--beige-light); }

        .info-section { background: var(--dark-choc); color: var(--beige); }
        .info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; max-width: 1100px; margin: 0 auto; }
        .info-card {
            background: rgba(250, 246, 241, 0.03); border: 1px solid rgba(158, 126, 90, 0.3); padding: 35px 25px;
            text-align: center; border-radius: 4px 16px 4px 16px; transition: all 0.4s ease;
        }
        .info-card:hover { border-color: var(--milk-choc); background: rgba(158, 126, 90, 0.06); }
        .info-icon { margin: 0 auto 15px; width: 40px; height: 40px; opacity: 0.8; }
        .info-title { font-family: 'Playfair Display', serif; font-size: 1.15rem; margin-bottom: 12px; color: var(--beige); }
        .info-text { color: var(--beige-dark); font-size: 0.85rem; line-height: 1.7; font-weight: 300; }
        .info-highlight { color: var(--milk-choc-light); font-weight: 400; }
        .payment-row { display: flex; justify-content: center; gap: 20px; margin-top: 50px; max-width: 1100px; margin-left: auto; margin-right: auto; flex-wrap: wrap; }
        .pay-badge { background: var(--beige-light); color: var(--dark-choc); padding: 10px 25px; border-radius: 30px; font-size: 0.75rem; letter-spacing: 2px; font-weight: 500; }

        .appointment { background: var(--beige); }
        .form-container { max-width: 850px; margin: 0 auto; }
        .form-group { margin-bottom: 25px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; }
        .form-group label { display: block; font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%; padding: 15px 18px; border: 1px solid var(--beige-dark); background: var(--beige-light);
            font-family: 'Montserrat', sans-serif; font-size: 0.9rem; color: var(--dark-choc); transition: border-color 0.3s ease; outline: none; border-radius: 4px;
            -webkit-appearance: none; appearance: none;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--milk-choc); }
        .form-group textarea { height: 120px; resize: vertical; }
        .form-submit {
            display: block; width: 100%; padding: 18px; background: var(--dark-choc); color: var(--beige);
            border: none; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; letter-spacing: 4px; text-transform: uppercase;
            cursor: pointer; transition: all 0.4s ease; margin-top: 10px; border-radius: 4px;
        }
        .form-submit:hover { background: var(--milk-choc); color: var(--dark-choc); }

        .contact { background: var(--beige-light); padding: 80px 40px; }
        .contact-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; max-width: 1000px; margin: 0 auto; text-align: center; }
        .contact-item h4 { font-family: 'Playfair Display', serif; font-size: 1.1rem; margin-bottom: 10px; color: var(--dark-choc); }
        .contact-item p, .contact-item a { color: var(--text-muted); font-size: 0.9rem; text-decoration: none; font-weight: 300; line-height: 1.8; transition: color 0.3s ease; }
        .contact-item a:hover { color: var(--milk-choc); }
        .footer { background: var(--dark-choc); padding: 50px 40px 40px; text-align: center; }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--beige); letter-spacing: 3px; margin-bottom: 15px; }
        .footer p { color: rgba(223, 211, 195, 0.5); font-size: 0.75rem; letter-spacing: 2px; }
        .social-links { display: flex; justify-content: center; gap: 18px; margin-bottom: 25px; }
        .social-links a { width: 40px; height: 40px; border: 1px solid rgba(158, 126, 90, 0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; }
        .social-links a:hover { border-color: var(--milk-choc); background: var(--milk-choc); }
        .social-links a svg { width: 16px; height: 16px; fill: var(--beige-dark); transition: fill 0.3s ease; }
        .social-links a:hover svg { fill: var(--dark-choc); }

        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(46, 27, 15, 0.78); z-index: 5000; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: all 0.4s ease; backdrop-filter: blur(5px); padding: 20px; }
        .modal-overlay.active { opacity: 1; visibility: visible; }
        .modal { background: var(--beige-light); padding: 45px 35px; text-align: center; max-width: 450px; width: 100%; border-radius: 8px; transform: scale(0.9); transition: transform 0.4s ease; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
        .modal-overlay.active .modal { transform: scale(1); }
        .modal-icon { width: 60px; height: 60px; margin: 0 auto 25px; border: 1px solid var(--milk-choc); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .modal h3 { font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 15px; color: var(--dark-choc); }
        .modal p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.6; margin-bottom: 30px; }
        .modal-close { display: inline-block; padding: 14px 40px; background: var(--milk-choc); color: var(--dark-choc); border: none; font-family: 'Montserrat', sans-serif; font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase; cursor: pointer; transition: all 0.3s ease; border-radius: 4px; }
        .modal-close:hover { background: var(--dark-choc); color: var(--beige); }

        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s ease; }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        @media (max-width: 1024px) {
            .nav { padding: 18px 30px; }
            .nav.scrolled { padding: 14px 30px; }
            .nav-links { gap: 20px; }
            .nav-links a { font-size: 0.68rem; letter-spacing: 2px; }
            .section { padding: 80px 30px; }
            .about-grid { gap: 60px; max-width: 950px; }
            .about-img::after { top: -8px; right: -8px; }
            .services-grid { gap: 25px; max-width: 900px; }
            .service-card { padding: 35px 25px; }
            .eye-grid { gap: 25px; max-width: 900px; }
            .eye-card { padding: 35px 20px; }
            .info-grid { gap: 25px; max-width: 900px; }
            .form-container { max-width: 750px; }
            .contact { padding: 70px 30px; }
            .contact-grid { gap: 35px; max-width: 900px; }
        }

        @media (max-width: 820px) {
            .nav-links { display: none; }
            .menu-toggle { display: flex; }
            .mobile-menu { display: flex; }
            .nav { padding: 15px 20px; }
            .section { padding: 70px 25px; }
            .section-header { margin-bottom: 50px; }
            .about-grid { grid-template-columns: 1fr; gap: 40px; max-width: 100%; }
            .about-img { max-width: 320px; margin: 0 auto; aspect-ratio: 4/5; }
            .about-img::after { top: -8px; right: -8px; }
            .about-text { text-align: center; }
            .about-text h3 { font-size: 1.5rem; }
            .about-sig { margin-top: 20px; }
            .services-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 100%; }
            .service-card { padding: 30px 20px; }
            .services-grid .service-card:last-child { grid-column: 1 / -1; max-width: 400px; margin: 0 auto; width: 100%; }
            .eye-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 100%; }
            .eye-card:nth-child(3) { grid-column: 1 / -1; max-width: 350px; margin: 0 auto; width: 100%; }
            .info-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 100%; }
            .info-card:nth-child(3) { grid-column: 1 / -1; max-width: 400px; margin: 0 auto; width: 100%; }
            .form-row { gap: 20px; }
            .contact-grid { grid-template-columns: repeat(2, 1fr); gap: 30px; max-width: 100%; }
            .contact-item:nth-child(3) { grid-column: 1 / -1; }
        }

        @media (max-width: 576px) {
            html { font-size: 15px; }
            .nav { padding: 12px 16px; height: 60px; }
            .nav.scrolled { padding: 10px 16px; }
            .nav-logo { font-size: 1rem; letter-spacing: 3px; }
            .lang-toggle { padding: 4px 10px; }
            .lang-toggle span { font-size: 0.62rem; }
            .menu-toggle span { width: 22px; }
            .mobile-menu a { font-size: 1.3rem; }
            .mobile-menu { gap: 22px; }
            .hero { min-height: 550px; }
            .hero-content { padding: 0 16px; }
            .hero-sub { font-size: 0.65rem; letter-spacing: 4px; margin-bottom: 18px; }
            .hero-title { font-size: 2.2rem; margin-bottom: 12px; }
            .hero-tag { font-size: 0.95rem; margin-bottom: 30px; }
            .hero-btn { padding: 14px 40px; font-size: 0.65rem; letter-spacing: 3px; }
            .scroll-ind { bottom: 25px; }
            .scroll-ind span { font-size: 0.55rem; }
            .scroll-line { height: 28px; }
            .section { padding: 60px 16px; }
            .section-header { margin-bottom: 40px; }
            .section-label { font-size: 0.62rem; letter-spacing: 4px; margin-bottom: 12px; }
            .section-title { font-size: 1.6rem; margin-bottom: 12px; }
            .section-line { width: 40px; }
            .about-grid { gap: 30px; }
            .about-img { max-width: 260px; }
